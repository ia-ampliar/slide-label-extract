{
    "slide_img_path": "data/slide_img.png",
    "output_boximg_path": "data/box_img.png",
    "output_image_path": "data/output/extracted_slide.jpg",
    "case_id_list": ["([A-Z]).*?(\\d{2}).*?-.*?(\\d{6})"],
    "mask_params": {
        "hsv_lower": [0, 0, 120],
        "hsv_upper": [179, 80, 255],
        "kernel_size": [25, 25],
        "morph_close_iterations": 2,
        "morph_open_iterations": 1,
        "binary_threshold": 10,
        "padding": 5,
        "draw_box_color": [0, 255, 0],
        "draw_box_thickness": 20
    },
    "ocr_params": {
        "roi_width_ratio": 0.25,
        "rotate_90": true,
        "tesseract_config": "--oem 3 --psm 6",
        "tesseract_lang": "por",
        "clahe_clip_limit": 2.0,
        "clahe_tile_grid": [8, 8],
        "upscale_factor": 2.0,
        "blur_kernel": [3, 3]
    }
}